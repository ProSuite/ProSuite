<controls:ProWindow x:Class="ProSuite.AGP.Display.ImportSLDLMDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProSuite.AGP.Display;assembly=ProSuite.AGP.Display"
        xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
        d:DataContext="{d:DesignInstance {x:Type local:ImportSLDLMOptions}, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="Import SLD/LM Configuration"
		ResizeMode="CanResizeWithGrip"
        SizeToContent="WidthAndHeight" MinWidth="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
	<StackPanel Margin="12">
		<TextBlock Padding="0,2,0,2">
            <Run Text="Active map: " />
            <Bold><Run Text="{Binding MapName,Mode=OneWay}"/></Bold>
        </TextBlock>

		<Label Padding="0,10,0,2" Target="{Binding ElementName=comboBoxLayer}">Import into entire map or group layer:</Label>
		<ComboBox Margin="2" Name="comboBoxLayer" IsEditable="False"
		          ItemsSource="{Binding GroupLayerItems, Mode=OneWay}"
		          SelectedItem="{Binding GroupLayerItem, Mode=TwoWay}"
		          DisplayMemberPath="Name" />

		<Label Padding="0,10,0,2">Path to config file to import (XML):</Label>
		<DockPanel>
            <Button DockPanel.Dock="Right"
                    Style="{DynamicResource Esri_Button}"
                    Content="Browse..." Click="BrowseButtonClicked" />
			<TextBox Padding="2" Margin="0,4,2,4"
                     Text="{Binding ConfigFilePath, UpdateSourceTrigger=PropertyChanged}" />
		</DockPanel>

		<DockPanel LastChildFill="False" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Content="Cancel" TabIndex="3"
                    Style="{DynamicResource Esri_Button}"
                    IsCancel="True" />
            <Button DockPanel.Dock="Right" Content="Import" TabIndex="2"
                    Style="{DynamicResource Esri_Button}"
                    IsEnabled="{Binding ImportButtonEnabled}"
                    IsDefault="True" Click="ImportButtonClicked" />
			<Button DockPanel.Dock="Left" Content="Validate" TabIndex="1"
                    Style="{DynamicResource Esri_Button}"
			        IsEnabled="{Binding ValidateButtonEnabled}"
                    Command="{Binding ValidateConfigCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
			        ToolTip="Validate config file (do not import)" />
		</DockPanel>
	</StackPanel>
</controls:ProWindow>
