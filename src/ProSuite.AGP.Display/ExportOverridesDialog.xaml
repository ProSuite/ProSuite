<controls:ProWindow x:Class="ProSuite.AGP.Display.ExportOverridesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:display="clr-namespace:ProSuite.AGP.Display;assembly=ProSuite.AGP.Display"
        xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
        d:DataContext="{d:DesignInstance {x:Type display:ExportOverridesOptions}, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="Export Overrides Configuration"
        ResizeMode="CanResizeWithGrip"
        SizeToContent="WidthAndHeight" MinWidth="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
	<StackPanel Margin="12">
		<TextBlock Padding="0,2,0,2">
            <Run Text="Active map: " />
            <Bold><Run Text="{Binding MapName,Mode=OneWay}"/></Bold>
        </TextBlock>

		<Label Padding="0,10,0,2" Target="{Binding ElementName=comboBoxLayer}">Export entire map or group layer:</Label>
        <ComboBox Margin="2" Name="comboBoxLayer" IsEditable="False"
                  ItemsSource="{Binding GroupLayerItems, Mode=OneWay}"
                  SelectedItem="{Binding GroupLayerItem, Mode=TwoWay}"
                  DisplayMemberPath="Name"/>

        <Label Padding="0,10,0,2" Target="{Binding ElementName=textBoxRemark}">Remark to add to the generated file:</Label>
        <TextBox Padding="2" Name="textBoxRemark" Text="{Binding Remark, Mode=TwoWay}" />

        <Label Padding="0,10,0,2">Path to config file (XML) to create/overwrite:</Label>
        <DockPanel>
            <Button DockPanel.Dock="Right" Style="{DynamicResource Esri_Button}"
                    Content="Browse..." Click="BrowseButtonClicked" />
			<TextBox Padding="2" Margin="0,4,2,4"
                     Text="{Binding ConfigFilePath, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <DockPanel LastChildFill="False" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Content="Cancel" TabIndex="2"
                    Style="{DynamicResource Esri_Button}"
                    IsCancel="True" />
            <Button DockPanel.Dock="Right" Content="Export" TabIndex="1"
                    Style="{DynamicResource Esri_Button}"
                    IsEnabled="{Binding ExportButtonEnabled}"
                    IsDefault="True" Click="ExportButtonClicked" />
        </DockPanel>
	</StackPanel>
</controls:ProWindow>
